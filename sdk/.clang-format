# Network Next SDK coding standard.
#
# Encodes the style the SDK has always used, so a formatting pass normalizes rather
# than restyles: 4-space indent, Allman braces, spaces inside parentheses (but not in
# C-style casts), middle pointer alignment (type * name), no column limit (existing
# line breaks are kept), no include sorting (include order is semantic in the
# platform files), preprocessor directives at column zero.
#
# The vendored trees are exempt: sdk/serialize (canonical upstream, never hand-edited)
# and sdk/sodium (vendored libsodium) each carry a DisableFormat config.
#
# Check: clang-format --dry-run --Werror  (run by the SDK Tests CI job)

Language: Cpp
Standard: Cpp03

UseTab: Never
IndentWidth: 4
TabWidth: 4
ColumnLimit: 0

BreakBeforeBraces: Allman
PointerAlignment: Middle
DerivePointerAlignment: false

SpaceBeforeParens: ControlStatements
SpacesInParens: Custom
SpacesInParensOptions:
  InConditionalStatements: true
  InCStyleCasts: false
  InEmptyParentheses: false
  Other: true
SpacesInSquareBrackets: false
SpaceAfterCStyleCast: true
SpaceBeforeAssignmentOperators: true

IndentCaseLabels: true
IndentCaseBlocks: false
IndentPPDirectives: None

# never force existing compact one-liners apart (the packet filter tables use
# one-line if/else blocks); with ColumnLimit 0 nothing is ever joined either
AllowShortBlocksOnASingleLine: Always
AllowShortIfStatementsOnASingleLine: AllIfsAndElse
AllowShortCaseLabelsOnASingleLine: true
AllowShortLoopsOnASingleLine: true
AllowShortFunctionsOnASingleLine: All

AlignAfterOpenBracket: Align
AlignOperands: Align
AlignTrailingComments:
  Kind: Leave
AlignConsecutiveMacros: None
AlignEscapedNewlines: Left

ReflowComments: false
SortIncludes: Never
MaxEmptyLinesToKeep: 1
KeepEmptyLinesAtTheStartOfBlocks: true
SeparateDefinitionBlocks: Leave
FixNamespaceComments: false
ContinuationIndentWidth: 4
AccessModifierOffset: -4
